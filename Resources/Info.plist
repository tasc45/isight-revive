<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDevelopmentRegion</key>
    <string>en</string>
    <key>CFBundleExecutable</key>
    <string>iSightRevive</string>
    <key>CFBundleIdentifier</key>
    <string>com.isightrevive.dal</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleName</key>
    <string>iSightRevive</string>
    <key>CFBundlePackageType</key>
    <string>BNDL</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0.0</string>
    <key>CFBundleVersion</key>
    <string>1</string>

    <!-- CFPlugIn registration: tells CoreMediaIO this is a DAL plugin -->
    <key>CFPlugInTypes</key>
    <dict>
        <!-- kCMIOHardwarePlugInTypeID -->
        <key>30010C1C-93BF-11D8-8B5B-000A95AF9C6A</key>
        <array>
            <!-- Our factory UUID -->
            <string>A1B2C3D4-E5F6-7890-ABCD-EF1234567890</string>
        </array>
    </dict>
    <key>CFPlugInFactories</key>
    <dict>
        <key>A1B2C3D4-E5F6-7890-ABCD-EF1234567890</key>
        <string>iSightRevivePluginFactory</string>
    </dict>
    <key>CFPlugInDynamicRegistration</key>
    <string>NO</string>
    <key>CFPlugInUnloadFunction</key>
    <string></string>

    <!-- No CMIOHardwareAssistantServiceNames — runs in-process, bypassing crashing IIDCVideoAssistant.
         No CMIOHardwarePlugInLazyLoadingInfo — always load so CMIO picks us up immediately. -->
</dict>
</plist>
